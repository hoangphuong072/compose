MINIHERMES_API_KEY=
MINIHERMES_MODEL=gpt-4o-mini
MINIHERMES_BASE_URL=https://api.openai.com/v1
MINIHERMES_TLS_VERIFY=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

MINIHERMES_ENABLED_TOOLSETS=file,memory,terminal,browser,credentials
MINIHERMES_SHOW_CONTEXT=false
MINIHERMES_CONTEXT_MAX_CHARS=4000

MINIHERMES_LOGGING_ENABLED=true
MINIHERMES_LOG_LEVEL=INFO
MINIHERMES_LOG_TO_CONSOLE=true
MINIHERMES_LOG_MAX_VALUE_CHARS=4000
MINIHERMES_LOG_SENSITIVE_DATA=false

MINIHERMES_WORKSPACE_HOST=./workspace
MINIHERMES_DATA_HOST=./data
MINIHERMES_WEB_HOST_PORT=8080
MINIHERMES_WEB_CONTAINER_PORT=8080
MINIHERMES_TELEGRAM_REQUIRED=false

CAMOUFOX_DATA_HOST=./camoufox-data
CAMOUFOX_PORT=9222
CAMOUFOX_HOST=0.0.0.0
CAMOUFOX_WS_PATH=camoufox
CAMOUFOX_WS_ENDPOINT=ws://camoufox:9222/camoufox
PLAYWRIGHT_FIREFOX_WS_ENDPOINT=ws://camoufox:9222/camoufox

CODEX_BINARY=codex
MINIHERMES_CODEX_MODEL=
MINIHERMES_CODEX_PROFILE=
MINIHERMES_CODEX_TIMEOUT=900
MINIHERMES_CODEX_SANDBOX=workspace-write
MINIHERMES_CODEX_APPROVAL=never
MINIHERMES_CODEX_SKIP_GIT_CHECK=true
MINIHERMES_CODEX_EPHEMERAL=false

PINCHTAB_BINARY=pinchtab
PINCHTAB_TOKEN=
